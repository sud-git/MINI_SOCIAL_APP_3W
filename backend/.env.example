# Backend Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
PORT=5000
NODE_ENV=development

# Database
# Local: mongodb://localhost:27017/social-post-app
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/social-post-app
MONGODB_URI=mongodb://localhost:27017/social-post-app

# JWT Configuration (Generate strong key: openssl rand -base64 32)
JWT_SECRET=generate-a-strong-random-secret-key-at-least-32-characters-long
JWT_EXPIRE=7d

# CORS & Frontend URL
FRONTEND_URL=http://localhost:3000

# Optional: Logging & Monitoring
# LOG_LEVEL=debug
# SENTRY_DSN=your_sentry_dsn_here
